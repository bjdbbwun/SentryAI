# python/collector.py
# Fetch fraud links from public APIs

import json
import requests
from datetime import datetime
from typing import List, Dict

class FraudLinkCollector:
    """Collects phishing and fraud links from public sources"""
    
    def __init__(self):
        self.all_frauds = []
    
    def fetch_from_urlhaus(self) -> List[Dict]:
        """Fetch malicious URLs from URLhaus"""
        try:
            url = "https://urlhaus.abuse.ch/downloads/csv_recent/"
            response = requests.get(url, timeout=30)
            links = []
            for line in response.text.split('\n')[1:]:
                if line and 'http' in line:
                    parts = line.split(',')
                    if len(parts) > 2:
                        links.append({
                            'url': parts[2].strip('"'),
                            'source': 'urlhaus',
                            'date': datetime.now().isoformat()
                        })
            print(f"✅ URLhaus: {len(links)} links")
            return links
        except Exception as e:
            print(f"❌ URLhaus error: {e}")
            return []
    
    def fetch_from_phishtank(self) -> List[Dict]:
        """Fetch phishing URLs from PhishTank"""
        try:
            url = "https://data.phishtank.com/data/online-valid.json"
            response = requests.get(url, timeout=30)
            data = response.json()
            links = []
            for item in data[:50]:
                links.append({
                    'url': item.get('url'),
                    'source': 'phishtank',
                    'date': datetime.now().isoformat(),
                    'phish_id': item.get('phish_id')
                })
            print(f"✅ PhishTank: {len(links)} links")
            return links
        except Exception as e:
            print(f"❌ PhishTank error: {e}")
            return []
    
    def fetch_from_openphish(self) -> List[Dict]:
        """Fetch phishing URLs from OpenPhish"""
        try:
            url = "https://openphish.com/feed.txt"
            response = requests.get(url, timeout=30)
            links = []
            for line in response.text.split('\n'):
                if line and line.startswith('http'):
                    links.append({
                        'url': line.strip(),
                        'source': 'openphish',
                        'date': datetime.now().isoformat()
                    })
            print(f"✅ OpenPhish: {len(links)} links")
            return links
        except Exception as e:
            print(f"❌ OpenPhish error: {e}")
            return []
    
    def fetch_from_ipvoid(self) -> List[Dict]:
        """Fetch from ipvoid (requires API key - optional)"""
        # This is a placeholder for future expansion
        return []
    
    def collect_all(self) -> List[Dict]:
        """Collect from all sources"""
        print("🕷️ Starting fraud link collection...")
        
        all_links = []
        all_links.extend(self.fetch_from_urlhaus())
        all_links.extend(self.fetch_from_phishtank())
        all_links.extend(self.fetch_from_openphish())
        
        # Remove duplicates
        unique_links = {}
        for link in all_links:
            url = link['url']
            if url not in unique_links:
                unique_links[url] = link
        
        result = list(unique_links.values())
        print(f"\n📊 Total unique links: {len(result)}")
        return result
    
    def save_to_json(self, links: List[Dict], filename: str = "data/threats.json"):
        """Save collected links to JSON file"""
        import os
        os.makedirs("data", exist_ok=True)
        
        with open(filename, 'w') as f:
            json.dump(links, f, indent=2)
        print(f"💾 Saved to {filename}")

if __name__ == "__main__":
    collector = FraudLinkCollector()
    threats = collector.collect_all()
    collector.save_to_json(threats)
    
    # Print sample
    print("\n📋 Sample links:")
    for threat in threats[:5]:
        print(f"  - {threat['url'][:80]}... ({threat['source']})")