// src/orchestrator.ts
// Master Orchestrator - All Layers Combined

import { fastScan } from './fastScan';
import { reputationScan } from './reputation';
import { behaviorScan } from './behavior';

export interface FinalResult {
  finalScore: number;
  finalVerdict: 'safe' | 'suspicious' | 'dangerous' | 'blocked';
  summary: string[];
  recommendation: string;
}

export async function fullScan(url: string, pageContent?: string): Promise<FinalResult> {
  const summary: string[] = [];
  let totalScore = 0;
  let layersRun = 0;
  
  // Layer 1+2: Fast Scan
  const fast = await fastScan(url);
  totalScore += fast.score;
  layersRun++;
  summary.push(`Fast scan: ${fast.score}% - ${fast.reasons.join(', ')}`);
  
  // If very dangerous, block immediately
  if (fast.score < 30) {
    return {
      finalScore: fast.score,
      finalVerdict: 'blocked',
      summary: [...summary, 'BLOCKED: High risk detected'],
      recommendation: 'Do not open this link - it appears to be fraudulent'
    };
  }
  
  // Layer 3: Reputation Scan
  const reputation = await reputationScan(url);
  totalScore += reputation.score;
  layersRun++;
  summary.push(`Reputation: ${reputation.score}% - ${reputation.reasons.join(', ')}`);
  
  // Layer 4: Behavioral Scan (if content available)
  let behavior = null;
  if (pageContent) {
    behavior = await behaviorScan(url, pageContent);
    totalScore += behavior.score;
    layersRun++;
    summary.push(`Behavioral: ${behavior.score}%`);
    if (behavior.suspiciousWords.length > 0) {
      summary.push(`Suspicious words found: ${behavior.suspiciousWords.join(', ')}`);
    }
  }
  
  // Calculate final score
  const finalScore = Math.round(totalScore / layersRun);
  
  // Determine verdict
  let finalVerdict: 'safe' | 'suspicious' | 'dangerous' | 'blocked';
  let recommendation = '';
  
  if (finalScore >= 80) {
    finalVerdict = 'safe';
    recommendation = '✓ Link appears safe to open';
  } else if (finalScore >= 50) {
    finalVerdict = 'suspicious';
    recommendation = '⚠️ Suspicious link - be careful and do not enter personal information';
  } else if (finalScore >= 25) {
    finalVerdict = 'dangerous';
    recommendation = '🚨 Dangerous link - we strongly recommend not opening it';
  } else {
    finalVerdict = 'blocked';
    recommendation = '❌ Link blocked - confirmed fraud detected';
  }
  
  return {
    finalScore,
    finalVerdict,
    summary,
    recommendation
  };
}

// Quick check function for simple testing
export async function quickCheck(url: string): Promise<string> {
  const result = await fullScan(url);
  return `[${result.finalVerdict.toUpperCase()}] ${result.recommendation} (Confidence: ${result.finalScore}%)`;
}